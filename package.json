{
  "name": "mcpinnit",
  "version": "0.1.0",
  "description": "Init your MCP server in 60 seconds.",
  "type": "module",
  "bin": {
    "mcpinnit": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
