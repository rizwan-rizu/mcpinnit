  },
  "homepage": "https://mcpinnit.com",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "ora": "^8.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
